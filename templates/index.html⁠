<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sonya AI</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            background-color: #0b0f19;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .container {
            text-align: center;
            padding: 20px;
        }

        /* Анимированная неоновая сфера Sonya */
        .sonya-sphere {
            width: 160px;
            height: 160px;
            background: radial-gradient(circle at 30% 30%, #22d3ee, #0ea5e9, #1e1b4b);
            border-radius: 50%;
            box-shadow: 0 0 40px rgba(34, 211, 238, 0.6), 
                        inset 0 0 20px rgba(255, 255, 255, 0.3);
            margin: 0 auto;
            cursor: pointer;
            transition: all 0.3s ease;
            animation: float 4s ease-in-out infinite;
        }

        .sonya-sphere:active {
            transform: scale(0.92);
            box-shadow: 0 0 60px rgba(34, 211, 238, 0.9);
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            margin-top: 40px;
            letter-spacing: -0.5px;
            background: linear-gradient(to right, #22d3ee, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        p {
            color: #64748b;
            font-size: 16px;
            max-width: 280px;
            margin-top: 10px;
            line-height: 1.5;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="sonya-sphere" id="voiceBtn"></div>
        <h1 id="statusText">Sonya AI</h1>
        <p id="subText">Нажми на сферу, чтобы начать общение, или просто пиши мне в чат бота</p>
    </div>

    <script>
        // Инициализируем Telegram WebApp
        const tg = window.Telegram.WebApp;
        tg.expand(); // Разворачиваем на весь экран
        
        // Настройка цветов под тему ТГ юзера
        tg.ready();

        const btn = document.getElementById('voiceBtn');
        const status = document.getElementById('statusText');

        btn.addEventListener('click', () => {
            status.innerText = "Слушаю...";
            // Тут в будущем будет захват микрофона через Web Audio API
            // А пока делаем виброотклик смартфона при нажатии
            if (tg.HapticFeedback) {
                tg.HapticFeedback.impactOccurred('medium');
            }
        });
    </script>
</body>
</html>
